---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{title}</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet">
</head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  /* 共通のCSS変数 */
  :root {
    --color-primary: #008080;
    --color-text: #333;
    --color-bg-light: #f9fbfb;
    --color-border: #e0e0e0;
    --font-family: 'Noto Sans JP', sans-serif;
  }

  /* フォント指定を追加 */
  body {
    font-family: var(--font-family);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  
  /* 以下、既存のレイアウト構造 */
  body { 
    display: flex; flex-direction: column; min-height: 100vh;
    color: var(--color-text);
    line-height: 1.6;
  }
  main { flex: 1; width: 100%; }

  /* 共通パーツ（ページヘッダー） */
  .p-page-header { background: linear-gradient(135deg, color-mix(in srgb, var(--color-primary) 15%, #fff) 0%, #ffffff 100%); padding-block: 40px; text-align: center; border-bottom: 1px solid var(--color-border); }
  .p-page-header__inner { max-width: 1200px; margin-inline: auto; padding-inline: 20px; }
  .p-page-header__title { font-size: 1.75rem; font-weight: 800; margin: 0 0 4px 0; }
  .p-page-header__en { font-size: 0.8rem; font-weight: 700; color: var(--color-primary); letter-spacing: 0.15em; }

  @media (min-width: 1025px) {
    .p-page-header { padding-block: 60px; }
    .p-page-header__title { font-size: 2.25rem; }
  }
</style>