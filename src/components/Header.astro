---
const navItems = [
  { href: '/about', label: '当院について' },
  { href: '/staff', label: 'スタッフ紹介' },
  { href: '/menu', label: '施術内容' },
  { href: '/info', label: '院内情報' },
  { href: '/news', label: '新着情報' },
];
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-header__logo">〇〇整骨院</a>

    <nav class="site-header__nav" id="js-nav">
      <ul class="site-header__menu">
        {navItems.map(item => (
          <li><a href={item.href} class="site-header__link">{item.label}</a></li>
        ))}
      </ul>
      <a href="/contact" class="site-header__btn">お問い合わせ</a>
    </nav>

    <button class="site-header__hamburger" id="js-hamburger" aria-label="メニュー開閉" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<script>
  const hamburger = document.getElementById('js-hamburger');
  const nav = document.getElementById('js-nav');

  hamburger?.addEventListener('click', () => {
    const isExpanded = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!isExpanded));
    nav?.classList.toggle('is-open');
    document.body.style.overflow = !isExpanded ? 'hidden' : '';
  });
</script>

<style is:global>
  /* 共通のヘッダー基本設定 */
  .site-header {
    position: sticky; top: 0; z-index: 999;
    background: #fff; height: 60px;
    display: flex; align-items: center; border-bottom: 1px solid #eee;
  }
  .site-header__inner {
    display: flex; justify-content: space-between; align-items: center;
    width: 100%; max-width: 1200px; margin: 0 auto; padding: 0 20px;
  }
  .site-header__logo { font-weight: 700; color: #008080; text-decoration: none; font-size: 1.25rem; }
  
  /* スマホ専用のハンバーガーボタン */
  .site-header__hamburger { display: flex; flex-direction: column; gap: 5px; border: none; background: none; }
  .site-header__hamburger span { display: block; width: 25px; height: 2px; background: #333; transition: 0.3s; }

  /* スマホ専用のドロワー（横からスライド） */
  .site-header__nav {
    position: fixed; top: 60px; right: 0; width: 300px; height: calc(100vh - 60px);
    background: #fff; display: flex; flex-direction: column; align-items: center;
    padding-top: 50px; gap: 20px;
    transform: translateX(100%);
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: -5px 0 15px rgba(0,0,0,0.1);
  }
  .site-header__nav.is-open { transform: translateX(0); }
  
  .site-header__menu { display: flex; flex-direction: column; align-items: center; gap: 20px; list-style: none; }
  .site-header__link { text-decoration: none; color: #333; font-weight: 600; }
  .site-header__btn { background: #008080; color: #fff; padding: 10px 20px; border-radius: 99px; text-decoration: none; }

/* --- PC版のレイアウト調整（1025px以上） --- */
  @media (min-width: 1025px) {
    .site-header { height: 80px; }
    .site-header__hamburger { display: none; }
    
    .site-header__nav {
      position: static; 
      width: auto; 
      height: auto; 
      transform: none;
      background: transparent; 
      box-shadow: none; 
      padding: 0;
      /* ここでFlexboxの挙動を修正 */
      display: flex !important; 
      flex-direction: row; 
      align-items: center; /* 垂直方向中央揃え */
      gap: 30px;           /* メニュー項目とボタンの間の余白 */
    }

    .site-header__menu { 
      display: flex; 
      flex-direction: row; 
      gap: 20px;          /* メニュー項目間の余白 */
      list-style: none;
      margin: 0; 
      padding: 0;
    }

    .site-header__link {
      white-space: nowrap; /* 改行させない */
    }
  }
</style>