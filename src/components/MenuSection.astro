---
const menus = [
  {
    title: "骨盤・骨格矯正",
    price: "¥5,500",
    time: "約45分",
    description: "体の土台となる骨盤のゆがみを整え、姿勢改善や慢性的な腰痛・肩こりを根本からケアします。",
    imgUrl: "https://images.unsplash.com/photo-1519824145371-296894a0daa9?q=80&w=600&auto=format&fit=crop"
  },
  {
    title: "筋肉・筋膜調整",
    price: "¥4,400",
    time: "約30分",
    description: "ガチガチに固まったトリガーポイント（コリの引き金）を的確にほぐし、血行を促進して痛みを和らげます。",
    imgUrl: "https://images.unsplash.com/photo-1600334129128-685c5582fd35?q=80&w=600&auto=format&fit=crop"
  },
  {
    title: "交通事故・むち打ち施術",
    price: "¥0",
    time: "相談料無料",
    description: "自賠責保険が適用されるため、窓口負担一律0円。事故後の怪我や頭痛、首の痛みに特化した専門施術です。",
    imgUrl: "https://images.unsplash.com/photo-1593113598332-cd288d649433?q=80&w=600&auto=format&fit=crop"
  }
];
---

<section class="p-menu-section">
  <div class="p-menu-section__inner">

    <div class="p-menu-section__header">
      <span class="p-menu-section__label">MENU</span>
      <h2 class="p-menu-section__title">施術メニュー・料金</h2>
    </div>

    <div class="p-menu-section__body">
      <div class="p-menu-section__grid">
        {menus.map((item) => (
          <div class="p-menu-section__card">
            <div class="p-menu-section__card-img">
              <img src={item.imgUrl} alt={item.title} loading="lazy" />
            </div>
            <div class="p-menu-section__card-body">
              <h3 class="p-menu-section__card-title">{item.title}</h3>
              <div class="p-menu-section__card-meta">
                <span class="p-menu-section__card-price">{item.price}</span>
                <span class="p-menu-section__card-time">（{item.time}）</span>
              </div>
              <p class="p-menu-section__card-text">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
      
      <div class="p-menu-section__actions">
        <a href="/menu" class="c-btn c-btn--primary">すべてのメニュー・料金を見る</a>
      </div>
    </div>

  </div>
</section>

<style>
  :root {
    --bp-tablet: 768px;
    --bp-pc: 1025px;
    --color-primary: #008080;
    --color-text: #333;
    --color-border: #e0e0e0;
  }

  .p-menu-section {
    padding-block: 60px;
    background-color: #fff;
  }

  .p-menu-section__inner {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: 20px;
  }

  .p-menu-section__header {
    text-align: center;
    margin-bottom: 40px;
  }

  .p-menu-section__label {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 8px;
  }

  .p-menu-section__title {
    font-size: 1.65rem;
    font-weight: 800;
    color: var(--color-text);
    margin: 0;
    position: relative;
    padding-bottom: 16px;

    &::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 40px;
      height: 3px;
      background-color: var(--color-primary);
      border-radius: 999px;
    }
  }

  .p-menu-section__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    margin-bottom: 40px;
  }

  .p-menu-section__card {
    background-color: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 25px rgb(0 0 0 / 5%);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
  }

  .p-menu-section__card-img {
    aspect-ratio: 16 / 9;
    width: 100%;
    overflow: hidden;
    
    & img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.3s ease;
    }
  }

  .p-menu-section__card:hover .p-menu-section__card-img img {
    transform: scale(1.05);
  }

  .p-menu-section__card-body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .p-menu-section__card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 8px 0;
  }

  .p-menu-section__card-meta {
    display: flex;
    align-items: baseline;
    margin-bottom: 16px;
  }

  .p-menu-section__card-price {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primary);
    font-family: 'Helvetica Neue', Arial, sans-serif;
  }

  .p-menu-section__card-time {
    font-size: 0.85rem;
    color: #666;
    font-weight: 600;
  }

  .p-menu-section__card-text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #555;
    margin: 0;
  }

  .p-menu-section__actions {
    text-align: center;
  }

  .c-btn {
    display: inline-block;
    padding: 16px 40px;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    background-color: var(--color-primary);
    text-decoration: none;
    transition: background-color 0.2s ease, transform 0.2s ease;
    box-shadow: 0 4px 15px rgb(0 128 128 / 20%);
    
    &:hover {
      background-color: color-mix(in srgb, var(--color-primary) 85%, black);
      transform: translateY(-2px);
    }
  }

  /* =================================================================
     PCサイズ（1025px以上）の解除・レイアウト調整
     ================================================================= */
  @media (min-width: 1025px) {
    .p-menu-section {
      padding-block: 80px;
    }

    .p-menu-section__header {
      margin-bottom: 56px;
    }

    .p-menu-section__title {
      font-size: 2rem;
    }

    .p-menu-section__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
      margin-bottom: 56px;
    }
  }
</style>